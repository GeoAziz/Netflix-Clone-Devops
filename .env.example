# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES (Safe to expose - prefixed with VITE_)
# ============================================================================

# Firebase Configuration (from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_app_id:web:your_web_id
VITE_FIREBASE_MEASUREMENT_ID=G-your_measurement_id

# Third-party APIs
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Error Tracking & Monitoring (Client-side)
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Application Configuration
VITE_APP_VERSION=1.0.0
VITE_API_BASE_URL=http://localhost:3000

# ============================================================================
# BACKEND ENVIRONMENT VARIABLES (Keep Private - Vercel Secrets Only)
# ============================================================================

# Firebase Admin SDK (convert serviceAccountKey.json to base64)
FIREBASE_SERVICE_ACCOUNT_KEY=your_base64_encoded_service_account_key
FIREBASE_ADMIN_SDK_URL=https://your-project.firebaseio.com

# Error Tracking & Monitoring (Server-side)
SENTRY_DSN=https://your-key@sentry.o4505941959524352.ingest.sentry.io/your-project-id

# Security & Sessions
SESSION_SECRET=your_random_64_character_session_secret_here_change_in_production
SECURE_COOKIE_ENABLED=true

# Environment
NODE_ENV=production
APP_VERSION=1.0.0

# ============================================================================
# VERCEL DEPLOYMENT
# ============================================================================
# Set via Vercel Dashboard: Settings > Environment Variables
# For local development: run `vercel env pull .env.local`
