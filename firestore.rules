rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User profiles - subcollection per user
    match /userProfiles/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Watch history - per user, per profile
    match /watchHistory/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // My List - per user, per profile
    match /myList/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Ratings - per user, per profile
    match /ratings/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Search history - per user
    match /searchHistory/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Subscriptions - per user, server writes, users read their own
    match /subscriptions/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only server can write subscriptions
    }

    // Notifications - read-only for users, server writes only
    match /notifications/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only server can write notifications
    }

    // MFA Settings - per user, server writes, users read their own
    match /mfaSettings/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only server can write MFA settings
    }

    // Login Activity - per user, server writes, users read their own
    match /loginActivity/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only server can write login activity
    }

    // Devices - per user, track device fingerprints and sessions
    match /devices/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Server writes, users can request deletion
    }

    // Profile PINs - per profile (optional, opt-in security)
    match /profilePINs/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Email Verification Tokens - temporary, server-only
    match /emailVerificationTokens/{document=**} {
      allow read, write: if false; // Only server writes
    }

    // Password Reset Tokens - temporary, server-only
    match /passwordResetTokens/{document=**} {
      allow read, write: if false; // Only server writes
    }

    // Account Audit Log - per user, server writes, users read their own
    match /auditLogs/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only server writes
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
